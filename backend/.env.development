# Local dev (single-process: API runs the worker in-process).
RECALL_ENVIRONMENT=development
RECALL_DATABASE_URL=postgresql+asyncpg://recall:recall@localhost:5432/recall
RECALL_REDIS_URL=redis://localhost:6379/0
RECALL_SECRET_KEY=dev-insecure-secret-change-me
RECALL_STORAGE_DIR=./.storage
RECALL_STORAGE_PUBLIC_URL=http://localhost:8000/storage
RECALL_EMBEDDING_PROVIDER=deterministic
RECALL_VECTOR_STORE_BACKEND=memory
RECALL_VECTOR_DIMENSION=1024
RECALL_RUN_WORKER_IN_PROCESS=true
