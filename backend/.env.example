# Recall backend configuration (copy to .env and adjust).
RECALL_ENVIRONMENT=development
RECALL_DATABASE_URL=postgresql+asyncpg://recall:recall@localhost:5432/recall
RECALL_REDIS_URL=redis://localhost:6379/0
RECALL_SECRET_KEY=change-me

# Storage
RECALL_STORAGE_DIR=/data/storage
RECALL_STORAGE_PUBLIC_URL=http://localhost:8000/storage

# CORS (comma-separated)
RECALL_CORS_ORIGINS=http://localhost:3000

# --- ML seams ---
# embedding_provider: huggingface | deterministic
RECALL_EMBEDDING_PROVIDER=deterministic
RECALL_EMBEDDING_MODEL=BAAI/bge-m3
RECALL_VECTOR_DIMENSION=1024
RECALL_MODEL_VERSION=v1
# vector_store_backend: memory | pgvector
RECALL_VECTOR_STORE_BACKEND=memory
# extraction seams (Phase 3): paddle|none, whisper|none, florence2|blip2|none
RECALL_OCR_BACKEND=none
RECALL_TRANSCRIPTION_BACKEND=none
RECALL_CAPTIONING_BACKEND=none
# chunking / retrieval
RECALL_CHUNK_CHAR_SIZE=2000
RECALL_CHUNK_OVERLAP=200
RECALL_RETRIEVAL_TOP_K=10
# ai enrichment: heuristic | none
RECALL_ENRICHMENT_BACKEND=heuristic

# Worker
RECALL_RUN_WORKER_IN_PROCESS=false
